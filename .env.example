# Root .env for docker-compose — copy this to .env and fill in HOST_IP.
#
# HOST_IP: the LAN IP address of the machine running Docker.
# Both the Expo Metro bundler QR code and the Athena API URL are derived from this.
#
# How to find your LAN IP:
#   Mac/Linux: ipconfig getifaddr en0   (or: ip route get 1 | awk '{print $7}')
#   Windows:   ipconfig  →  look for "IPv4 Address" under your Wi-Fi adapter
#
# Example:
# HOST_IP=192.168.1.42
HOST_IP=
